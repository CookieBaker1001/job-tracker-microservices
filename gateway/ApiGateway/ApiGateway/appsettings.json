{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "api/auth/{**catch-all}"
        }
      },
      "job-route": {
        "ClusterId": "job-cluster",
        "Match": {
          "Path": "api/jobs/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-destination": {
            "Address": "https://localhost:5001/"
          }
        }
      },
      "job-cluster": {
        "Destinations": {
          "job-destination": {
            "Address": "https://localhost:5002/"
          }
        }
      }
    }
  }
}
